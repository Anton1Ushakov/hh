# HH.ru API Configuration
HH_CLIENT_ID=your_client_id_here
HH_CLIENT_SECRET=your_client_secret_here
HH_REDIRECT_URI=http://localhost:8000/auth/callback

# Access Token for Resume Search
HH_ACCESS_TOKEN=your_access_token_here
HH_REFRESH_TOKEN=your_refresh_token_here

# User Agent for HH API
HH_USER_AGENT="YourApp (your-email@example.com)"

# Database
DATABASE_URL=sqlite:///./hh_analyzer.db

# Application
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
