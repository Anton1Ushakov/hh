# HH.ru API Configuration (required for auto token refresh)
# Register app at https://dev.hh.ru
HH_CLIENT_ID=your_client_id_here
HH_CLIENT_SECRET=your_client_secret_here

# Local development
HH_REDIRECT_URI=http://localhost:8000/auth/callback
# Production example:
# HH_REDIRECT_URI=https://your-app.onrender.com/auth/callback

# OAuth tokens
# HH_REFRESH_TOKEN is required — access is refreshed automatically on startup and before expiry
HH_REFRESH_TOKEN=your_refresh_token_here
# HH_ACCESS_TOKEN is optional — will be obtained via refresh if missing or expired
HH_ACCESS_TOKEN=

# User Agent for HH API
HH_USER_AGENT="YourApp (your-email@example.com)"

# Database
# Local:
DATABASE_URL=sqlite:///./hh_analyzer.db
# Render with persistent disk:
# DATABASE_URL=sqlite:////data/hh_analyzer.db

# Application
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
PORT=8000
